---
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import { ViewTransitions } from "astro:transitions";

import { SITE_TITLE, SITE_DESCRIPTION, TRANSITION_API } from "../config";

const {
  image,
  title = SITE_TITLE,
  description = SITE_DESCRIPTION,
  sideBarActiveItemID,
  ogType,
} = Astro.props;

const navItems = [
  { id: "home", label: "Home", href: "/" },
  { id: "blog", label: "Blog", href: "/blog/" },
  { id: "projects", label: "Projects", href: "/projects" },
  { id: "about", label: "About", href: "/about" },
];
---

<!doctype html>
<html lang="ko" data-theme="cmyk">
  <head>
    <BaseHead title={title} description={description} image={image} ogType={ogType} />
    {TRANSITION_API && <ViewTransitions />}
  </head>
  <body class="bg-base-100 min-h-screen flex flex-col">
    <!-- Top Navigation -->
    <header class="navbar bg-base-100 border-b border-base-200 sticky top-0 z-50 backdrop-blur bg-opacity-90 px-6 lg:px-10">
      <div class="navbar-start">
        <a href="/" class="site-logo">Marie Note</a>
      </div>
      <div class="navbar-end">
        <ul class="menu menu-horizontal gap-1 hidden md:flex">
          {navItems.map((item) => (
            <li>
              <a
                href={item.href}
                class:list={[
                  "nav-item",
                  sideBarActiveItemID === item.id && "active"
                ]}
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
        <button id="menu-open" class="md:hidden cursor-pointer p-2">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="w-6 h-6 stroke-current stroke-[1.5]">
            <path stroke-linecap="round" d="M4 7h16M4 17h16"></path>
          </svg>
        </button>
      </div>
    </header>

    <!-- Main Content -->
    <div class="flex-1 flex justify-center">
      <main class="mt-[36px] px-[24px] py-0 w-full max-w-[820px]">
        <slot />
      </main>
    </div>

    <!-- Mobile Menu Overlay -->
    <div id="mobile-menu" class="fixed inset-0 bg-base-100 z-[100] flex-col px-6 pt-4 opacity-0 pointer-events-none transition-opacity duration-200">

      <div class="flex justify-end">
        <button id="menu-close" class="cursor-pointer p-2">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="w-6 h-6 stroke-current stroke-[1.5]">
            <path stroke-linecap="round" d="M6 6l12 12M6 18L18 6"></path>
          </svg>
        </button>
      </div>
      <nav class="mt-10 px-2">
        {navItems.map((item, i) => (
          <a
            href={item.href}
            class:list={[
              "mobile-nav-item block text-[1.75rem] font-bold py-4 text-gray-900 no-underline",
              sideBarActiveItemID === item.id && "text-primary"
            ]}
            style={`transition-delay: ${i * 50}ms`}
          >
            {item.label}
          </a>
        ))}
      </nav>
    </div>

    <Footer />

    <style is:global>
      /* Logo: Cormorant Garamond lowercase italic */
      .site-logo {
        font-family: 'Playfair Display', serif;
        font-weight: 600;
        font-size: 1.3rem;
        letter-spacing: -0.01em;
        color: inherit;
        text-decoration: none;
      }

      /* Nav items: Playfair Display to match logo tone */
      .nav-item {
        font-family: 'Playfair Display', serif;
        font-weight: 400;
        font-size: 0.95rem;
        letter-spacing: 0.02em;
        text-transform: lowercase;
      }

      /* Mobile menu slide-up animation */
      .mobile-nav-item {
        opacity: 0;
        transform: translateY(16px);
        transition: opacity 0.3s ease, transform 0.3s ease;
      }
      .mobile-nav-item.show {
        opacity: 1;
        transform: translateY(0);
      }
    </style>

    <script>
      document.addEventListener('astro:page-load', () => {
        const menu = document.getElementById('mobile-menu');
        const openBtn = document.getElementById('menu-open');
        const closeBtn = document.getElementById('menu-close');

        const navItems = menu?.querySelectorAll('.mobile-nav-item');

        openBtn?.addEventListener('click', () => {
          menu?.classList.add('flex');
          requestAnimationFrame(() => {
            menu?.classList.remove('opacity-0', 'pointer-events-none');
            menu?.classList.add('opacity-100');
            navItems?.forEach((item) => item.classList.add('show'));
          });
          document.body.style.overflow = 'hidden';
        });

        closeBtn?.addEventListener('click', () => {
          menu?.classList.remove('opacity-100');
          menu?.classList.add('opacity-0', 'pointer-events-none');
          navItems?.forEach((item) => item.classList.remove('show'));
          document.body.style.overflow = '';
          setTimeout(() => menu?.classList.remove('flex'), 300);
        });
      });
    </script>

  </body>
</html>
