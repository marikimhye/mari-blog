---
import { type BlogSchema } from "../content/config";
import BaseLayout from "./BaseLayout.astro";
import dayjs from "dayjs";
import "dayjs/locale/ko";
import { Image } from "astro:assets";

export interface Props extends BlogSchema {}

const { title, description, pubDate, updatedDate, heroImage, badge, tags = [] } = Astro.props;
dayjs.locale("ko");
const displayDate = dayjs(pubDate).format("YYYY-MM-DD");
---

<BaseLayout title={title} description={description} image={heroImage}, ogType="article">
  <main class="flex justify-center">
    <article class="w-full max-w-[47.5rem]">
      <!-- 타이틀 영역 -->
      <div class="mb-[33px] text-center">
        <h1 class="text-[32px] font-bold leading-tight tracking-tight mb-4 break-keep">{title}</h1>
        <time class="text-[16px] text-gray-500">{displayDate}</time>
      </div>

      {/* 설명 */}
      {description && <p class="text-gray-500 text-[15px] mb-8 break-keep text-center leading-relaxed">{description}</p>}

      <!-- 히어로 이미지 -->
      {heroImage && <Image width={750} height={422} format="webp" src={heroImage} alt={title} class="w-full rounded-2xl mb-10" />}

      <!-- 구분선 -->
      <div class="border-t border-gray-200 mb-10"></div>

      <!-- 본문 -->
      <div class="prose prose-lg max-w-none prose-img:rounded-2xl prose-img:mx-auto post-body text-[17px]">
        <slot />
      </div>

      <!-- 하단 프로필 영역 -->
      <div class="mt-16 pt-10">
        <!-- 블로그 소개 -->
        <div class="flex items-center gap-4 mb-12">
          <div class="w-14 h-14 rounded-full bg-gray-100 flex items-center justify-center shrink-0">
            <span class="text-2xl font-light italic font-serif">m</span>
          </div>
          <div>
            <p class="font-semibold text-[15px]">marie</p>
            <p class="text-[13px] text-gray-500 leading-snug">AI로 일하는 방식을 바꾸는 PM의 실험 기록</p>
          </div>
        </div>

        <!-- 태그 -->
        {tags.length > 0 && (
          <div class="flex flex-wrap gap-3 mb-10">
            {tags.map((tag) => (
              <a href={`/blog/tag/${tag}`} class="rounded-full bg-gray-100 px-3 py-1 text-xs text-gray-600 underline decoration-gray-300 hover:bg-gray-200 hover:decoration-gray-500 transition-colors">
                #{tag}
              </a>
            ))}
          </div>
        )}

        <!-- 블로그 홈 버튼 -->
        <div class="flex justify-center mt-16 mb-16">
          <a href="/blog/" class="inline-block px-8 py-3 bg-gray-100 rounded-full text-[15px] font-medium text-gray-700 no-underline hover:bg-gray-200 transition-colors">
            블로그 홈
          </a>
        </div>
      </div>
    </article>
  </main>
</BaseLayout>

<style>
  .post-body :global(p) {
    word-break: keep-all;
    margin-top: 0 !important;
    margin-bottom: 12px !important;
    line-height: 1.6 !important;
    letter-spacing: 0;
  }

  .post-body :global(h2) {
    margin-top: 52px !important;
    margin-right: 0 !important;
    margin-bottom: 13px !important;
    font-weight: 700;
    font-size: 1.625rem;
  }

  .post-body :global(h3) {
    margin-top: 2rem;
    margin-bottom: 0.5rem;
    font-weight: 600;
  }

  .post-body :global(li) {
    margin-top: 0.25rem;
    margin-bottom: 0.25rem;
  }

  .post-body :global(blockquote) {
    font-style: normal;
    border-left-color: #e5e7eb;
  }
</style>
