---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
---

<BaseLayout title="Projects" sideBarActiveItemID="projects">
  <div>
    <div class="text-3xl w-full font-bold mb-2">AI로 만든 도구들</div>
    <p class="mb-6 opacity-70">Claude Code를 활용해 직접 만든 프로젝트들입니다.</p>
  </div>

  <HorizontalCard
    title="KISA 스팸민원 자동화"
    img="/post_img.webp"
    desc="엑셀 파일에서 스팸 신고 내역을 읽어 DOCX/PDF 조치내역서를 자동 생성하는 도구."
    url="#"
    badge="AI Built"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="Claude Code 비개발자 가이드"
    img="/post_img.webp"
    desc="개발 경험 없는 PM이 Claude Code를 셋팅하고 실무에 적용하기까지의 가이드."
    url="#"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="Claude Code 생산성 사례집"
    img="/post_img.webp"
    desc="PM 관점에서 Claude Code로 달성한 생산성 개선 사례를 정리한 인터랙티브 페이지."
    url="#"
  />
</BaseLayout>
